{
  "skill": {
    "name": "crypto_cold_wallet_purchase",
    "display_name": "加密冷钱包购买",
    "version": "1.0.0",
    "description": "自动化购买加密货币冷钱包的完整流程，支持多币种支付和物流追踪",
    "author": "Funshell 方贝科技",
    "category": "e-commerce",
    "tags": ["crypto", "cold-wallet", "e-commerce", "payment", "blockchain"],
    "language": "zh-CN",
    "icon": "🔐",
    
    "capabilities": [
      "浏览冷钱包产品目录",
      "创建购买订单",
      "生成加密货币支付地址",
      "确认支付交易",
      "查询订单状态",
      "追踪物流信息",
      "自动提醒和通知"
    ],
    
    "supported_cryptocurrencies": [
      "BTC", "ETH", "BNB", "SOL", "DOGE", "TRX"
    ],
    
    "api": {
      "base_url": "https://funshell-nextjs.vercel.app",
      "authentication": {
        "type": "api_key",
        "header": "X-API-Key",
        "format": "fsk_[64_hex_characters]"
      },
      "rate_limit": {
        "requests_per_minute": 60,
        "requests_per_hour": 1000
      }
    },
    
    "configuration": {
      "required": [],
      "optional": [
        {
          "name": "default_currency",
          "type": "string",
          "enum": ["BTC", "ETH", "BNB", "SOL", "DOGE", "TRX"],
          "default": "BTC",
          "description": "默认支付币种"
        },
        {
          "name": "auto_check_interval",
          "type": "number",
          "default": 21600,
          "unit": "seconds",
          "description": "自动检查订单状态的间隔（默认6小时）"
        },
        {
          "name": "payment_reminder_interval",
          "type": "number",
          "default": 7200,
          "unit": "seconds",
          "description": "支付提醒间隔（默认2小时）"
        }
      ]
    },
    
    "intents": [
      {
        "name": "browse_products",
        "description": "浏览冷钱包产品",
        "examples": [
          "我想买冷钱包",
          "有什么冷钱包可以买",
          "显示所有产品",
          "查看冷钱包列表",
          "推荐一个冷钱包"
        ],
        "action": "list_products"
      },
      {
        "name": "create_order",
        "description": "创建购买订单",
        "examples": [
          "我要买 Ledger Nano X",
          "下单购买",
          "创建订单",
          "我要这个",
          "购买第一个"
        ],
        "required_entities": ["product"],
        "optional_entities": ["quantity", "payment_currency"],
        "action": "create_order"
      },
      {
        "name": "confirm_payment",
        "description": "确认支付完成",
        "examples": [
          "我已经支付了",
          "支付完成",
          "交易哈希是 xxx",
          "tx hash: xxx",
          "已转账"
        ],
        "required_entities": ["tx_hash"],
        "action": "confirm_payment"
      },
      {
        "name": "check_order_status",
        "description": "查询订单状态",
        "examples": [
          "订单状态",
          "我的订单怎么样了",
          "发货了吗",
          "查询订单",
          "物流信息"
        ],
        "action": "check_order"
      }
    ],
    
    "entities": [
      {
        "name": "product",
        "type": "string",
        "description": "产品名称或ID",
        "extraction": "fuzzy_match"
      },
      {
        "name": "quantity",
        "type": "number",
        "description": "购买数量",
        "default": 1,
        "min": 1,
        "max": 10
      },
      {
        "name": "payment_currency",
        "type": "enum",
        "values": ["BTC", "ETH", "BNB", "SOL", "DOGE", "TRX"],
        "description": "支付币种"
      },
      {
        "name": "tx_hash",
        "type": "string",
        "pattern": "^[a-fA-F0-9]{64}$",
        "description": "区块链交易哈希"
      },
      {
        "name": "shipping_info",
        "type": "object",
        "properties": {
          "name": { "type": "string", "required": true },
          "phone": { "type": "string", "required": true },
          "address": { "type": "string", "required": true },
          "city": { "type": "string", "required": true },
          "province": { "type": "string", "required": true },
          "country": { "type": "string", "default": "中国" },
          "postal_code": { "type": "string", "required": true }
        }
      }
    ],
    
    "actions": [
      {
        "name": "initialize",
        "description": "初始化 Skill，创建 API Key",
        "endpoint": {
          "method": "POST",
          "path": "/api/v1/api-keys",
          "headers": {
            "Content-Type": "application/json"
          },
          "body": {
            "name": "{{agent_name}}",
            "email": "{{agent_email}}",
            "agentType": "{{agent_type}}",
            "description": "Auto-generated by skill"
          }
        },
        "response_handler": {
          "success": {
            "save": {
              "api_key": "data.key",
              "api_key_id": "data.id"
            },
            "message": "✅ API 访问凭证已获取"
          },
          "error": {
            "message": "❌ 初始化失败: {{error}}"
          }
        }
      },
      {
        "name": "list_products",
        "description": "获取产品列表",
        "endpoint": {
          "method": "GET",
          "path": "/api/v1/products"
        },
        "response_handler": {
          "success": {
            "format": "product_list",
            "message": "📦 以下是可购买的冷钱包：\n\n{{formatted_products}}\n\n请告诉我您想要哪一款？"
          }
        },
        "formatters": {
          "product_list": "{{#each data}}\n{{@index}}. {{name}} - {{price}} {{currency}}\n   品牌：{{brand}} | 型号：{{model}}\n   库存：{{stock}} 件\n   {{description}}\n{{/each}}"
        }
      },
      {
        "name": "create_order",
        "description": "创建订单",
        "prerequisites": [
          {
            "check": "api_key_exists",
            "action": "initialize"
          },
          {
            "check": "shipping_info_exists",
            "action": "ask_shipping_info"
          }
        ],
        "endpoint": {
          "method": "POST",
          "path": "/api/v1/orders",
          "headers": {
            "X-API-Key": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "body": {
            "product_id": "{{product_id}}",
            "quantity": "{{quantity}}",
            "payment_currency": "{{payment_currency}}",
            "shipping": "{{shipping_info}}"
          }
        },
        "response_handler": {
          "success": {
            "save": {
              "order_id": "data.order_id",
              "order_number": "data.order_number",
              "payment_address": "data.payment.address",
              "payment_amount": "data.payment.amount",
              "payment_currency": "data.payment.currency"
            },
            "message": "✅ 订单创建成功！\n\n📦 订单信息：\n订单号：{{data.order_number}}\n产品：{{data.product.name}}\n数量：{{data.quantity}}\n总价：{{data.total_price}} HKD\n\n💰 支付信息：\n币种：{{data.payment.currency}}\n金额：{{data.payment.amount}}\n地址：{{data.payment.address}}\n\n⏰ 请在 24 小时内完成支付\n支付后请告诉我交易哈希（TX Hash）",
            "schedule": {
              "action": "remind_payment",
              "delay": 7200
            }
          },
          "error": {
            "insufficient_stock": "❌ 库存不足，为您推荐其他产品...",
            "invalid_product": "❌ 产品不存在，请重新选择",
            "default": "❌ 订单创建失败: {{error}}"
          }
        }
      },
      {
        "name": "confirm_payment",
        "description": "确认支付",
        "prerequisites": [
          {
            "check": "order_id_exists",
            "message": "请先创建订单"
          }
        ],
        "endpoint": {
          "method": "POST",
          "path": "/api/v1/orders/{{order_id}}/payment",
          "headers": {
            "X-API-Key": "{{api_key}}",
            "Content-Type": "application/json"
          },
          "body": {
            "tx_hash": "{{tx_hash}}"
          }
        },
        "response_handler": {
          "success": {
            "save": {
              "order_status": "paid",
              "paid_at": "data.payment.paid_at"
            },
            "message": "✅ 支付已确认！\n\n订单号：{{data.order_number}}\n状态：已支付\n交易哈希：{{data.payment.tx_hash}}\n\n我们将在 1-2 个工作日内发货\n您可以随时查询订单状态",
            "schedule": {
              "action": "check_order",
              "delay": 21600,
              "repeat": true
            }
          },
          "error": {
            "invalid_tx_hash": "❌ 交易哈希格式不正确，请检查后重新提交",
            "order_not_found": "❌ 订单不存在",
            "default": "❌ 支付确认失败: {{error}}"
          }
        }
      },
      {
        "name": "check_order",
        "description": "查询订单状态",
        "endpoint": {
          "method": "GET",
          "path": "/api/v1/orders/{{order_id}}",
          "headers": {
            "X-API-Key": "{{api_key}}"
          }
        },
        "response_handler": {
          "success": {
            "save": {
              "order_status": "data.status",
              "tracking_number": "data.tracking_number"
            },
            "message": {
              "pending_payment": "⏰ 订单待支付\n\n订单号：{{data.order_number}}\n请尽快完成支付\n\n支付信息：\n币种：{{data.payment.currency}}\n金额：{{data.payment.amount}}\n地址：{{data.payment.address}}",
              "paid": "✅ 订单已支付\n\n订单号：{{data.order_number}}\n我们已收到您的付款\n预计 1-2 个工作日内发货",
              "processing": "📦 订单处理中\n\n订单号：{{data.order_number}}\n正在准备发货...",
              "shipped": "🚚 订单已发货！\n\n订单号：{{data.order_number}}\n快递公司：顺丰速运\n快递单号：{{data.tracking_number}}\n预计送达：1-3 天\n\n查询物流：https://www.sf-express.com/cn/sc/dynamic_function/waybill/#search/bill-number/{{data.tracking_number}}",
              "completed": "✅ 订单已完成\n\n感谢您的购买！\n如有任何问题，请随时联系我们",
              "cancelled": "❌ 订单已取消\n\n订单号：{{data.order_number}}\n如需重新下单，请告诉我"
            },
            "notify_on_change": true
          }
        }
      },
      {
        "name": "ask_shipping_info",
        "description": "询问收货信息",
        "type": "dialog",
        "message": "请提供收货信息：\n\n1️⃣ 姓名\n2️⃣ 电话\n3️⃣ 详细地址\n4️⃣ 城市\n5️⃣ 省份\n6️⃣ 邮编\n\n您可以一次性提供，或分步告诉我",
        "collect": [
          {
            "entity": "shipping_info.name",
            "prompt": "请提供收货人姓名："
          },
          {
            "entity": "shipping_info.phone",
            "prompt": "请提供联系电话："
          },
          {
            "entity": "shipping_info.address",
            "prompt": "请提供详细地址："
          },
          {
            "entity": "shipping_info.city",
            "prompt": "请提供城市："
          },
          {
            "entity": "shipping_info.province",
            "prompt": "请提供省份："
          },
          {
            "entity": "shipping_info.postal_code",
            "prompt": "请提供邮编："
          }
        ]
      },
      {
        "name": "remind_payment",
        "description": "提醒用户支付",
        "type": "notification",
        "message": "⏰ 支付提醒\n\n您的订单 {{order_number}} 还未支付\n请尽快完成支付以确保及时发货\n\n支付信息：\n币种：{{payment_currency}}\n金额：{{payment_amount}}\n地址：{{payment_address}}"
      }
    ],
    
    "state_management": {
      "persistent": [
        "api_key",
        "api_key_id",
        "user_info",
        "shipping_info",
        "active_orders"
      ],
      "session": [
        "current_order_id",
        "selected_product",
        "payment_currency"
      ]
    },
    
    "scheduled_tasks": [
      {
        "name": "check_active_orders",
        "interval": 21600,
        "action": "check_order",
        "condition": "has_active_orders"
      },
      {
        "name": "cleanup_completed_orders",
        "interval": 86400,
        "action": "cleanup_old_orders",
        "condition": "has_completed_orders_older_than_7_days"
      }
    ],
    
    "error_handling": {
      "retry": {
        "max_attempts": 3,
        "backoff": "exponential",
        "initial_delay": 1000
      },
      "fallback": {
        "api_error": "转人工客服",
        "network_error": "稍后重试",
        "validation_error": "请求用户重新输入"
      }
    },
    
    "documentation": {
      "playbook": "/AGENT_PLAYBOOK.md",
      "workflow": "/AGENT_WORKFLOW.json",
      "landing_page": "/agent/index.html",
      "api_docs": "https://funshell-nextjs.vercel.app/agent/index.html"
    },
    
    "examples": [
      {
        "title": "完整购买流程",
        "conversation": [
          {
            "user": "我想买冷钱包",
            "agent": "[调用 list_products]\n显示产品列表"
          },
          {
            "user": "我要 Ledger Nano X，用 BTC 支付",
            "agent": "[调用 ask_shipping_info]\n询问收货信息"
          },
          {
            "user": "张三，138 0000 0000，深圳市南山区科技园，深圳，广东，518000",
            "agent": "[调用 create_order]\n创建订单并显示支付信息"
          },
          {
            "user": "已支付，tx: a1b2c3d4...",
            "agent": "[调用 confirm_payment]\n确认支付成功"
          },
          {
            "user": "订单发货了吗？",
            "agent": "[调用 check_order]\n显示订单状态和物流信息"
          }
        ]
      }
    ],
    
    "metadata": {
      "created_at": "2024-03-05",
      "updated_at": "2024-03-05",
      "license": "MIT",
      "support_email": "support@funshell.com",
      "homepage": "https://funshell-nextjs.vercel.app"
    }
  }
}
